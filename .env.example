# ── Required ──
GEMINI_API_KEY=your_api_key_here

# ── Optional: Override defaults ──
# BROWSER_AGENT_MODEL=gemini-3-flash-preview
# BROWSER_AGENT_PROVIDER=google
# BROWSER_AGENT_HOME_URL=https://www.google.com
# BROWSER_AGENT_VIEWPORT_WIDTH=1280
# BROWSER_AGENT_VIEWPORT_HEIGHT=900
# BROWSER_AGENT_SCREENSHOT_QUALITY=70
# BROWSER_AGENT_SIDEBAR_WIDTH_RATIO=0.3
# BROWSER_AGENT_THEME=dark
# BROWSER_AGENT_WINDOW_WIDTH=1400
# BROWSER_AGENT_WINDOW_HEIGHT=900
# BROWSER_AGENT_RECURSION_LIMIT=100
# BROWSER_AGENT_REASONING_EFFORT=medium
# BROWSER_AGENT_GUARDRAIL_SENSITIVITY=medium   # low, medium, high

# ── Local Model (Ollama / LM Studio) ──
# BROWSER_AGENT_MODEL=llava:13b
# BROWSER_AGENT_PROVIDER=openai
# BROWSER_AGENT_BASE_URL=http://localhost:11434/v1
# BROWSER_AGENT_REASONING_EFFORT=low
